{
  "name": "runbook-workspace",
  "private": true,
  "type": "module",
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "scripts": {
    "dev": "pnpm --filter @runbook/web dev",
    "dev:server": "pnpm --filter @runbook/server dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "prepare": "husky",
    "migrate:up": "pnpm --filter @runbook/server migrate:up",
    "migrate:down": "pnpm --filter @runbook/server migrate:down",
    "migrate:status": "pnpm --filter @runbook/server migrate:status",
    "migrate:create": "pnpm --filter @runbook/server migrate:create"
  }
}
