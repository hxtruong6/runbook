{
  "id": "32co-chairside",
  "name": "32CO Chairside",
  "description": "Reference bundle for the 32CO chairside ortho review flow.",
  "createdAt": "2026-05-12T00:00:00Z",
  "versions": [
    {
      "version": "1.0.0",
      "releasedAt": "2026-05-12T00:00:00Z",
      "releaseNotes": "Initial bundle. Captures the 9 HTTP endpoints used in the chairside flow plus 3 reference scenarios.",
      "changes": [
        { "type": "added", "target": "signin", "summary": "POST /v1/user/auth/signin" },
        { "type": "added", "target": "profile", "summary": "GET /v1/user/auth/profile" },
        { "type": "added", "target": "featureHighlightsGet", "summary": "GET /v1/aligner/dentist/feature-highlights" },
        { "type": "added", "target": "featureHighlightsDismiss", "summary": "PUT /v1/aligner/dentist/feature-highlights" },
        { "type": "added", "target": "verifyDeviceToken", "summary": "POST /v1/aligner/user/ortho-reviews/chairside/device-token" },
        { "type": "added", "target": "startChairside", "summary": "POST /v1/aligner/user/ortho-reviews/chairside" },
        { "type": "added", "target": "uploadPhoto", "summary": "POST /v1/aligner/user/ortho-reviews/chairside/:orthoReviewId/photos" },
        { "type": "added", "target": "getOrthoReview", "summary": "GET /v1/aligner/dentist/ortho-reviews/:orthoReviewId" },
        { "type": "added", "target": "updateChairsideStatus", "summary": "PUT /v1/aligner/user/ortho-reviews/chairside/:orthoReviewId" }
      ],
      "blocks": [
        {
          "kind": "signin",
          "label": "Sign in (POST /v1/user/auth/signin)",
          "auth": "none",
          "inputs": [
            { "name": "email", "label": "Email", "type": "string", "required": true, "fromContextKey": "email" },
            { "name": "password", "label": "Password", "type": "password", "required": true }
          ],
          "outputs": [
            { "jsonPath": "jwt", "contextKey": "jwt" },
            { "jsonPath": "_id", "contextKey": "userId" }
          ],
          "request": {
            "method": "POST",
            "urlTemplate": "/v1/user/auth/signin",
            "headers": { "x-client-version": "0.4.0", "accept": "application/json" },
            "bodyTemplate": { "email": "{{email}}", "password": "{{password}}" }
          }
        },
        {
          "kind": "profile",
          "label": "§1 Profile (GET /v1/user/auth/profile)",
          "auth": "cookie-or-jwt",
          "inputs": [],
          "outputs": [
            { "jsonPath": "orthoReviewChairsideToken", "contextKey": "orthoReviewChairsideToken" },
            { "jsonPath": "isChairsideEnabled", "contextKey": "isChairsideEnabled" }
          ],
          "request": {
            "method": "GET",
            "urlTemplate": "/v1/user/auth/profile",
            "headers": { "accept": "application/json", "x-client-version": "0.4.0" }
          }
        },
        {
          "kind": "featureHighlightsGet",
          "label": "§2 Feature highlights — GET",
          "auth": "cookie-or-jwt",
          "inputs": [],
          "outputs": [
            { "jsonPath": "showChairsideInstallBanner", "contextKey": "showChairsideInstallBanner" }
          ],
          "request": {
            "method": "GET",
            "urlTemplate": "/v1/aligner/dentist/feature-highlights",
            "headers": { "accept": "application/json", "x-client-version": "0.4.0" }
          }
        },
        {
          "kind": "featureHighlightsDismiss",
          "label": "§3 Feature highlights — Dismiss (PUT)",
          "auth": "cookie-or-jwt",
          "inputs": [],
          "outputs": [],
          "request": {
            "method": "PUT",
            "urlTemplate": "/v1/aligner/dentist/feature-highlights",
            "headers": { "accept": "application/json", "x-client-version": "0.4.0" },
            "bodyTemplate": { "showChairsideInstallBanner": false }
          }
        },
        {
          "kind": "verifyDeviceToken",
          "label": "§4 Verify device token (phone first-pair)",
          "auth": "none",
          "inputs": [
            {
              "name": "orthoReviewChairsideToken",
              "label": "Chairside install token",
              "type": "string",
              "required": true,
              "fromContextKey": "orthoReviewChairsideToken"
            }
          ],
          "outputs": [
            { "jsonPath": "user.id", "contextKey": "userId" },
            { "jsonPath": "practices[0].id", "contextKey": "practiceId" },
            { "jsonPath": "corporate", "contextKey": "corporate" }
          ],
          "request": {
            "method": "POST",
            "urlTemplate": "/v1/aligner/user/ortho-reviews/chairside/device-token",
            "headers": { "accept": "application/json" },
            "bodyTemplate": { "token": "{{orthoReviewChairsideToken}}" }
          }
        },
        {
          "kind": "startChairside",
          "label": "§5 Start chairside review",
          "auth": "none",
          "inputs": [
            { "name": "firstName", "label": "First name", "type": "string", "required": true },
            { "name": "lastName", "label": "Last name", "type": "string", "required": true },
            { "name": "practiceId", "label": "Practice ID", "type": "string", "required": true, "fromContextKey": "practiceId" },
            {
              "name": "orthoReviewChairsideToken",
              "label": "Chairside token",
              "type": "string",
              "required": true,
              "fromContextKey": "orthoReviewChairsideToken"
            }
          ],
          "outputs": [
            { "jsonPath": "syncToken", "contextKey": "syncToken" },
            { "jsonPath": "orthoReview.id", "contextKey": "orthoReviewId" }
          ],
          "request": {
            "method": "POST",
            "urlTemplate": "/v1/aligner/user/ortho-reviews/chairside",
            "headers": { "accept": "application/json" },
            "bodyTemplate": {
              "firstName": "{{firstName}}",
              "lastName": "{{lastName}}",
              "practiceId": "{{practiceId}}",
              "orthoReviewChairsideToken": "{{orthoReviewChairsideToken}}"
            }
          }
        },
        {
          "kind": "uploadPhoto",
          "label": "§6 Upload photo",
          "auth": "none",
          "inputs": [
            { "name": "orthoReviewId", "label": "Ortho review ID", "type": "string", "required": true, "fromContextKey": "orthoReviewId" },
            { "name": "syncToken", "label": "Sync token", "type": "string", "required": true, "fromContextKey": "syncToken" },
            { "name": "slot", "label": "Slot", "type": "enum", "required": true, "enumValues": ["chairside-full-face", "chairside-close-up", "chairside-upper-arch", "chairside-lower-arch"] },
            { "name": "url", "label": "Photo URL", "type": "string", "required": true, "placeholder": "https://..." },
            { "name": "socketSessionUuid", "label": "Socket session UUID (optional)", "type": "string", "fromContextKey": "socketSessionUuid" }
          ],
          "outputs": [],
          "request": {
            "method": "POST",
            "urlTemplate": "/v1/aligner/user/ortho-reviews/chairside/{{orthoReviewId}}/photos",
            "headers": { "accept": "application/json" },
            "query": { "socketSessionUuid": "{{socketSessionUuid}}" },
            "bodyTemplate": {
              "syncToken": "{{syncToken}}",
              "slot": "{{slot}}",
              "url": "{{url}}"
            }
          }
        },
        {
          "kind": "getOrthoReview",
          "label": "§7 Get ortho review (DENTIST)",
          "auth": "cookie-or-jwt",
          "inputs": [
            { "name": "orthoReviewId", "label": "Ortho review ID", "type": "string", "required": true, "fromContextKey": "orthoReviewId" }
          ],
          "outputs": [
            { "jsonPath": "$", "contextKey": "orthoReview" }
          ],
          "request": {
            "method": "GET",
            "urlTemplate": "/v1/aligner/dentist/ortho-reviews/{{orthoReviewId}}",
            "headers": { "accept": "application/json", "x-client-version": "0.4.0" }
          }
        },
        {
          "kind": "updateChairsideStatus",
          "label": "§8 Update chairside status",
          "auth": "none",
          "inputs": [
            { "name": "orthoReviewId", "label": "Ortho review ID", "type": "string", "required": true, "fromContextKey": "orthoReviewId" },
            { "name": "syncToken", "label": "Sync token", "type": "string", "required": true, "fromContextKey": "syncToken" },
            { "name": "chairsideStatus", "label": "Chairside status", "type": "enum", "required": true, "enumValues": ["IN_PROGRESS", "COMPLETED", "ARCHIVED"] }
          ],
          "outputs": [
            { "jsonPath": "chairsideStatus", "contextKey": "chairsideStatus" }
          ],
          "request": {
            "method": "PUT",
            "urlTemplate": "/v1/aligner/user/ortho-reviews/chairside/{{orthoReviewId}}",
            "headers": { "accept": "application/json" },
            "bodyTemplate": {
              "syncToken": "{{syncToken}}",
              "chairsideStatus": "{{chairsideStatus}}"
            }
          }
        }
      ],
      "scenarios": [
        {
          "id": "prebuilt-happy-path",
          "name": "Chairside happy path",
          "createdAt": "2026-05-12T00:00:00Z",
          "blocks": [
            { "id": "b1", "kind": "signin", "overrides": { "email": "truong.hoang+chairside-p001@32co.com", "password": "P@ss123456_" } },
            { "id": "b2", "kind": "profile", "overrides": {} },
            { "id": "b3", "kind": "startChairside", "overrides": { "firstName": "Test", "lastName": "Patient" } },
            { "id": "b4", "kind": "uploadPhoto", "overrides": { "slot": "chairside-full-face", "url": "https://example.com/full-face.jpg" } },
            { "id": "b5", "kind": "uploadPhoto", "overrides": { "slot": "chairside-close-up", "url": "https://example.com/close-up.jpg" } },
            { "id": "b6", "kind": "uploadPhoto", "overrides": { "slot": "chairside-upper-arch", "url": "https://example.com/upper.jpg" } },
            { "id": "b7", "kind": "uploadPhoto", "overrides": { "slot": "chairside-lower-arch", "url": "https://example.com/lower.jpg" } },
            { "id": "b8", "kind": "getOrthoReview", "overrides": {} },
            { "id": "b9", "kind": "updateChairsideStatus", "overrides": { "chairsideStatus": "COMPLETED" } }
          ]
        },
        {
          "id": "prebuilt-phone-first-pair",
          "name": "Phone first-pair",
          "createdAt": "2026-05-12T00:00:00Z",
          "blocks": [
            { "id": "b1", "kind": "verifyDeviceToken", "overrides": { "orthoReviewChairsideToken": "0e0ee405c57b90f97c7cd330380e9730" } }
          ]
        },
        {
          "id": "prebuilt-dismiss-banner",
          "name": "Dismiss install banner",
          "createdAt": "2026-05-12T00:00:00Z",
          "blocks": [
            { "id": "b1", "kind": "signin", "overrides": { "email": "truong.hoang+chairside-p001@32co.com", "password": "P@ss123456_" } },
            { "id": "b2", "kind": "featureHighlightsGet", "overrides": {} },
            { "id": "b3", "kind": "featureHighlightsDismiss", "overrides": {} }
          ]
        }
      ],
      "environments": [
        {
          "id": "default-32co-alpha",
          "name": "32CO alpha",
          "baseUrl": "https://api-truong.32co.com",
          "auth": { "kind": "cookie" },
          "headers": {},
          "createdAt": "2026-05-12T00:00:00Z"
        }
      ],
      "docs": {
        "signin": "## Sign in\nAuthenticates and returns a session JWT.",
        "profile": "## Profile\nReturns the active user's profile including chairside-related tokens.",
        "uploadPhoto": "## Upload photo\nSubmit a chairside photo for a given slot. Pass `socketSessionUuid` to enable echo suppression in Socket.IO."
      }
    }
  ]
}
