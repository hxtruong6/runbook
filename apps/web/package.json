{
  "name": "@runbook/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3005",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 3000",
    "test": "vitest run",
