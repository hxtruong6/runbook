{
  "id": "github-rest",
  "name": "GitHub REST API",
  "description": "Bearer-auth starter for GitHub's v3 REST API.",
  "createdAt": "2026-05-15T00:00:00Z",
  "versions": [
    {
      "version": "1.0.0",
      "releasedAt": "2026-05-15T00:00:00Z",
      "releaseNotes": "Initial bundle. Three blocks covering user lookup, repo listing, and issue creation.",
      "changes": [
        { "type": "added", "target": "getUser", "summary": "GET /users/:username" },
        { "type": "added", "target": "listRepos", "summary": "GET /users/:username/repos" },
        { "type": "added", "target": "createIssue", "summary": "POST /repos/:owner/:repo/issues" }
      ],
      "blocks": [
        {
          "kind": "getUser",
          "label": "Get User (GET /users/:username)",
          "auth": "bearer",
          "inputs": [
            { "name": "username", "label": "Username", "type": "string", "required": true }
          ],
          "outputs": [],
          "request": {
            "method": "GET",
            "urlTemplate": "https://api.github.com/users/{{username}}",
            "headers": { "Accept": "application/vnd.github+json", "X-GitHub-Api-Version": "2022-11-28" },
            "bodyTemplate": null
          }
        },
        {
          "kind": "listRepos",
          "label": "List Repos (GET /users/:username/repos)",
          "auth": "bearer",
          "inputs": [
            { "name": "username", "label": "Username", "type": "string", "required": true },
            { "name": "per_page", "label": "Per page", "type": "number", "required": false }
          ],
          "outputs": [],
          "request": {
            "method": "GET",
            "urlTemplate": "https://api.github.com/users/{{username}}/repos?per_page={{per_page}}",
            "headers": { "Accept": "application/vnd.github+json", "X-GitHub-Api-Version": "2022-11-28" },
            "bodyTemplate": null
          }
        },
        {
          "kind": "createIssue",
          "label": "Create Issue (POST /repos/:owner/:repo/issues)",
          "auth": "bearer",
          "inputs": [
            { "name": "owner", "label": "Owner", "type": "string", "required": true },
            { "name": "repo", "label": "Repo", "type": "string", "required": true },
            { "name": "title", "label": "Title", "type": "string", "required": true },
            { "name": "body", "label": "Body", "type": "string", "required": false }
          ],
          "outputs": [{ "jsonPath": "$.number", "contextKey": "issueNumber" }],
          "request": {
            "method": "POST",
            "urlTemplate": "https://api.github.com/repos/{{owner}}/{{repo}}/issues",
            "headers": { "Accept": "application/vnd.github+json", "Content-Type": "application/json", "X-GitHub-Api-Version": "2022-11-28" },
            "bodyTemplate": "{\"title\":\"{{title}}\",\"body\":\"{{body}}\"}"
          }
        }
      ],
      "scenarios": [
        {
          "id": "github-rest-get-user",
          "name": "Fetch a user",
          "createdAt": "2026-05-15T00:00:00Z",
          "reusable": false,
          "blocks": [
            { "id": "s1-b1", "kind": "getUser", "overrides": { "username": "octocat" } }
          ]
        },
        {
          "id": "github-rest-list-repos",
          "name": "List repos",
          "createdAt": "2026-05-15T00:00:00Z",
          "reusable": false,
          "blocks": [
            { "id": "s2-b1", "kind": "getUser", "overrides": { "username": "octocat" } },
            { "id": "s2-b2", "kind": "listRepos", "overrides": { "username": "octocat", "per_page": 10 } }
          ]
        }
      ],
      "environments": [
        {
          "id": "github-env-default",
          "name": "GitHub (token required)",
          "baseUrl": "https://api.github.com",
          "auth": { "kind": "bearer", "token": "" },
          "headers": {},
          "createdAt": "2026-05-15T00:00:00Z"
        }
      ],
      "docs": {
        "overview": "Set your GitHub personal access token in the environment before running scenarios that require auth."
      }
    }
  ]
}
