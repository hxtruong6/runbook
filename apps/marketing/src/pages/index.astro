                  <rect x="32" y="24" width="32" height="40" rx="4" fill="#f3f1ea" stroke="#d6d1c2" stroke-width="1"/>
                  <text x="48" y="48" font-family="var(--font-mono), monospace" font-size="8" fill="#7c766a" text-anchor="middle">.json</text>
                  <text x="72" y="36" font-family="Inter, sans-serif" font-size="11" fill="#28241e" font-weight="600">payments-api.bundle</text>
                  <!-- Versions -->
                  <rect x="72" y="42" width="36" height="14" rx="4" fill="#e6fcf5"/>
                  <text x="90" y="52" font-family="Inter, sans-serif" font-size="8.5" fill="#099268" font-weight="700" text-anchor="middle">v2.1.0</text>
                  <rect x="114" y="42" width="36" height="14" rx="4" fill="#f3f1ea"/>
                  <text x="132" y="52" font-family="Inter, sans-serif" font-size="8.5" fill="#7c766a" font-weight="600" text-anchor="middle">v2.0.1</text>
                  <rect x="156" y="42" width="36" height="14" rx="4" fill="#f3f1ea"/>
                  <text x="174" y="52" font-family="Inter, sans-serif" font-size="8.5" fill="#7c766a" font-weight="600" text-anchor="middle">v1.9.0</text>
                  <!-- Divider -->
                  <line x1="32" y1="74" x2="228" y2="74" stroke="#e8e4d8" stroke-width="1"/>
                  <!-- Signed badge -->
                  <rect x="32" y="82" width="64" height="18" rx="5" fill="#f3f0ff" stroke="#b197fc" stroke-width="1"/>
                  <text x="64" y="94" font-family="Inter, sans-serif" font-size="8.5" fill="#6741d9" font-weight="700" text-anchor="middle">Signed ✓</text>
                  <!-- Scenarios count -->
                  <text x="108" y="94" font-family="Inter, sans-serif" font-size="9" fill="#7c766a">12 scenarios · 34 blocks</text>
                  <!-- Self-contained badge -->
                  <rect x="32" y="108" width="80" height="14" rx="4" fill="#fff8e1"/>
                  <text x="72" y="118" font-family="Inter, sans-serif" font-size="8" fill="#f08c00" font-weight="600" text-anchor="middle">Self-contained</text>
                </svg>
              </div>
            </div>

