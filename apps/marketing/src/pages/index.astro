---
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? '/app';
const GITHUB_URL = 'https://github.com/hxtruong6/runbook';
const CONTACT_EMAIL = 'hxtruong6@gmail.com';

const title = 'Runbook — The versioned, runnable API integration kit';
const description =
  'Build API workflows from reusable blocks. Ship them as a single signed bundle. Stay in sync as APIs change.';
const ogImage = '/og-image.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://runbook.app/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Canonical -->
    <link rel="canonical" href="https://runbook.app/" />

    <!-- Preload inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />

    <style>
      /* =============================================
         Design tokens — mirrors apps/web/src/theme.ts
         Primary: violet · Secondary: teal · Accent: amber
         ============================================= */
      :root {
        --violet-0: #f3f0ff;
        --violet-1: #e5dbff;
        --violet-2: #d0bfff;
        --violet-3: #b197fc;
        --violet-4: #9775fa;
        --violet-5: #845ef7;
        --violet-6: #7048e8;
        --violet-7: #6741d9;
        --violet-8: #5f3dc4;
        --violet-9: #5028b8;

        --teal-0: #e6fcf5;
        --teal-1: #c3fae8;
        --teal-2: #96f2d7;
        --teal-3: #63e6be;
        --teal-4: #38d9a9;
        --teal-5: #20c997;
        --teal-6: #12b886;
        --teal-7: #0ca678;
        --teal-8: #099268;
        --teal-9: #087f5b;

        --amber-0: #fff8e1;
        --amber-1: #ffecb5;
        --amber-2: #ffe082;
        --amber-3: #ffd54f;
        --amber-4: #ffca28;
        --amber-5: #ffc107;
        --amber-6: #ffb300;
        --amber-7: #f08c00;
        --amber-8: #e67700;
        --amber-9: #b26a00;

        --warm-gray-0: #fafaf7;
        --warm-gray-1: #f3f1ea;
        --warm-gray-2: #e8e4d8;
        --warm-gray-3: #d6d1c2;
        --warm-gray-4: #a8a292;
        --warm-gray-5: #7c766a;
        --warm-gray-6: #5c564c;
        --warm-gray-7: #403b33;
        --warm-gray-8: #28241e;
        --warm-gray-9: #15120e;

        --white: #fafaf7;
        --black: #15120e;

        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 14px;
        --radius-xl: 20px;

        --shadow-xs: 0 1px 2px rgba(15, 23, 42, 0.05);
        --shadow-sm: 0 2px 6px rgba(15, 23, 42, 0.07), 0 1px 2px rgba(15, 23, 42, 0.04);
        --shadow-md: 0 4px 12px rgba(15, 23, 42, 0.08), 0 2px 4px rgba(15, 23, 42, 0.05);
        --shadow-lg: 0 10px 24px rgba(15, 23, 42, 0.10), 0 4px 8px rgba(15, 23, 42, 0.05);

        --border-color: rgba(15, 23, 42, 0.08);

        --font-sans: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        --font-mono: ui-monospace, Menlo, Monaco, "Cascadia Code", "Courier New", monospace;
      }

      /* ---- Reset ---- */
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: var(--font-sans);
        background: var(--warm-gray-0);
        color: var(--warm-gray-8);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      /* ---- Skip link ---- */
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: var(--violet-7);
        color: #fff;
        padding: 8px 16px;
        border-radius: var(--radius-md);
        font-weight: 600;
        z-index: 999;
        transition: top 0.2s;
        text-decoration: none;
      }
      .skip-link:focus { top: 8px; }

      /* ---- Focus ring (WCAG 2.4.7) ---- */
      :focus-visible {
        outline: 2px solid var(--violet-6);
        outline-offset: 2px;
        border-radius: var(--radius-sm);
      }

      /* ---- Reduced motion (WCAG 2.3.3) ---- */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }

      /* ---- Layout ---- */
      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 24px;
      }

      /* ---- Nav ---- */
      nav {
        position: sticky;
        top: 0;
        background: rgba(250, 250, 247, 0.92);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-color);
        z-index: 100;
      }
      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 60px;
        gap: 24px;
      }
      .nav-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--warm-gray-9);
        letter-spacing: -0.02em;
      }
      .nav-logo-mark {
        width: 28px;
        height: 28px;
        background: var(--violet-7);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .nav-links a {
        color: var(--warm-gray-6);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        padding: 6px 12px;
        border-radius: var(--radius-md);
        transition: background 0.15s, color 0.15s;
      }
      .nav-links a:hover {
        background: var(--warm-gray-2);
        color: var(--warm-gray-8);
      }
      .btn-nav-cta {
        background: var(--violet-7);
        color: #fff !important;
        border-radius: var(--radius-md) !important;
        font-weight: 600 !important;
        transition: background 0.15s !important;
      }
      .btn-nav-cta:hover { background: var(--violet-8) !important; }

      /* ---- Buttons ---- */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border-radius: var(--radius-md);
        font-family: var(--font-sans);
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: -0.005em;
        cursor: pointer;
        border: none;
        text-decoration: none;
        transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
        min-height: 44px;
      }
      .btn:active { transform: translateY(1px); }
      .btn-primary {
        background: var(--violet-7);
        color: #fff;
        box-shadow: var(--shadow-sm);
      }
      .btn-primary:hover { background: var(--violet-8); box-shadow: var(--shadow-md); }
      .btn-secondary {
        background: var(--warm-gray-1);
        color: var(--warm-gray-8);
        border: 1px solid var(--border-color);
      }
      .btn-secondary:hover { background: var(--warm-gray-2); }
      .btn-ghost {
        background: transparent;
        color: var(--warm-gray-6);
        border: 1px solid var(--border-color);
      }
      .btn-ghost:hover { background: var(--warm-gray-1); color: var(--warm-gray-8); }

      /* ---- Section spacing ---- */
      section { padding: 80px 0; }
      .section-label {
        display: inline-block;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--violet-7);
        background: var(--violet-0);
        padding: 4px 12px;
        border-radius: 999px;
        margin-bottom: 16px;
      }
      h1, h2, h3, h4 {
        font-weight: 650;
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin: 0;
      }

      /* ---- Hero ---- */
      #hero {
        padding: 100px 0 80px;
        text-align: center;
        background: linear-gradient(180deg, var(--warm-gray-0) 0%, var(--violet-0) 100%);
      }
      .hero-tagline {
        font-size: clamp(2rem, 5vw, 3.25rem);
        color: var(--warm-gray-9);
        margin-bottom: 20px;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
      }
      .hero-tagline span { color: var(--violet-7); }
      .hero-sub {
        font-size: 1.15rem;
        color: var(--warm-gray-5);
        max-width: 560px;
        margin: 0 auto 36px;
        line-height: 1.65;
      }
      .hero-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 56px;
      }
      .hero-badges {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
        font-size: 0.82rem;
        color: var(--warm-gray-5);
        align-items: center;
      }
      .hero-badge-item {
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .hero-badge-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--teal-6);
        flex-shrink: 0;
      }
      /* Product video placeholder */
      .product-video-wrap {
        max-width: 860px;
        margin: 0 auto;
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--border-color);
        background: var(--warm-gray-8);
        aspect-ratio: 16 / 9;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }
      .product-video-poster {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .product-video-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        background: rgba(21, 18, 14, 0.55);
        color: #fff;
      }
      .play-btn {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        border: 2px solid rgba(255, 255, 255, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px);
      }
      .play-btn svg { margin-left: 4px; }
      .video-caption { font-size: 0.9rem; opacity: 0.7; }

      /* ---- Problem section ---- */
      #problem { background: var(--white); }
      .problem-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: center;
        margin-top: 48px;
      }
      .problem-heading { font-size: clamp(1.5rem, 3vw, 2rem); color: var(--warm-gray-9); margin-bottom: 24px; }
      .problem-bullets { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 20px; }
      .problem-bullets li {
        display: flex;
        gap: 16px;
        align-items: flex-start;
      }
      .problem-icon {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-md);
        background: var(--amber-0);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 2px;
      }
      .problem-bullets strong { display: block; font-size: 0.95rem; color: var(--warm-gray-8); margin-bottom: 2px; }
      .problem-bullets span { font-size: 0.88rem; color: var(--warm-gray-5); }
      /* Chaos diagram */
      .chaos-diagram {
        background: var(--warm-gray-1);
        border-radius: var(--radius-xl);
        border: 1px solid var(--border-color);
        padding: 32px;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .chaos-item {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.88rem;
        color: var(--warm-gray-6);
        box-shadow: var(--shadow-xs);
      }
      .chaos-item-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .chaos-label {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--warm-gray-4);
        margin-bottom: 4px;
      }
      .chaos-arrow {
        text-align: center;
        color: var(--warm-gray-3);
        font-size: 1.25rem;
        line-height: 1;
      }

      /* ---- How it works ---- */
      #how { background: var(--warm-gray-0); }
      .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 48px; }
      .step {
        background: var(--white);
        border-radius: var(--radius-xl);
        border: 1px solid var(--border-color);
        padding: 32px 28px;
        box-shadow: var(--shadow-xs);
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .step-number {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-md);
        background: var(--violet-7);
        color: #fff;
        font-size: 0.9rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .step h3 { font-size: 1.05rem; color: var(--warm-gray-9); }
      .step p { font-size: 0.88rem; color: var(--warm-gray-5); margin: 0; line-height: 1.6; }
      /* Step SVG diagrams */
      .step-diagram {
        border-radius: var(--radius-lg);
        background: var(--warm-gray-1);
        border: 1px solid var(--border-color);
        padding: 16px;
        margin-top: auto;
      }

      /* ---- Gallery ---- */
      #gallery { background: var(--white); }
      .gallery-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 48px; }
      .gallery-card {
        background: var(--warm-gray-1);
        border-radius: var(--radius-xl);
        border: 1px solid var(--border-color);
        aspect-ratio: 16 / 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        color: var(--warm-gray-4);
        transition: box-shadow 0.15s, transform 0.1s;
        cursor: pointer;
        text-decoration: none;
      }
      .gallery-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
      .gallery-card-title { font-size: 0.9rem; font-weight: 600; color: var(--warm-gray-5); }
      .gallery-tag {
        font-size: 0.73rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: var(--violet-0);
        color: var(--violet-7);
        padding: 3px 10px;
        border-radius: 999px;
      }
      .gallery-cta { text-align: center; margin-top: 32px; }

      /* ---- Badge preview ---- */
      #badge { background: var(--warm-gray-0); }
      .badge-section-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: center;
        margin-top: 48px;
      }
      .badge-preview-area {
        display: flex;
        flex-direction: column;
        gap: 16px;
        align-items: flex-start;
      }
      .run-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--violet-7);
        color: #fff;
        font-family: var(--font-sans);
        font-size: 0.82rem;
        font-weight: 600;
        padding: 7px 14px;
        border-radius: var(--radius-md);
        text-decoration: none;
        box-shadow: var(--shadow-sm);
        transition: background 0.15s;
      }
      .run-badge:hover { background: var(--violet-8); }
      .run-badge-flat {
        background: var(--warm-gray-8);
      }
      .run-badge-outline {
        background: transparent;
        border: 1.5px solid var(--violet-7);
        color: var(--violet-7);
      }
      .badge-code {
        background: var(--warm-gray-8);
        border-radius: var(--radius-lg);
        padding: 20px 24px;
        font-family: var(--font-mono);
        font-size: 0.82rem;
        color: var(--teal-3);
        line-height: 1.7;
        overflow-x: auto;
        width: 100%;
      }
      .badge-code .comment { color: var(--warm-gray-5); }
      .badge-code .str { color: var(--amber-4); }
      .badge-desc { font-size: 0.9rem; color: var(--warm-gray-5); line-height: 1.65; }
      .badge-desc strong { color: var(--warm-gray-8); }

      /* ---- Open source ---- */
      #oss { background: var(--white); }
      .oss-inner { text-align: center; max-width: 680px; margin: 0 auto; }
      .oss-inner h2 { font-size: clamp(1.6rem, 3vw, 2.25rem); color: var(--warm-gray-9); margin-bottom: 16px; }
      .oss-inner p { font-size: 1rem; color: var(--warm-gray-5); margin-bottom: 32px; line-height: 1.65; }
      .oss-features { display: flex; gap: 32px; justify-content: center; margin-bottom: 36px; flex-wrap: wrap; }
      .oss-feature { display: flex; flex-direction: column; align-items: center; gap: 8px; }
      .oss-feature-icon {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-lg);
        background: var(--teal-0);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .oss-feature-text { font-size: 0.85rem; font-weight: 600; color: var(--warm-gray-6); }
      .github-star-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: var(--warm-gray-9);
        color: #fff;
        border-radius: var(--radius-md);
        font-weight: 600;
        font-size: 0.95rem;
        padding: 12px 28px;
        text-decoration: none;
        box-shadow: var(--shadow-sm);
        transition: background 0.15s;
        min-height: 44px;
      }
      .github-star-btn:hover { background: var(--warm-gray-8); }

      /* ---- Footer ---- */
      footer {
        background: var(--warm-gray-9);
        color: var(--warm-gray-3);
        padding: 48px 0 32px;
      }
      .footer-inner { display: flex; justify-content: space-between; align-items: flex-start; gap: 32px; flex-wrap: wrap; }
      .footer-brand { display: flex; flex-direction: column; gap: 8px; }
      .footer-logo { font-size: 1rem; font-weight: 700; color: var(--white); letter-spacing: -0.02em; }
      .footer-tagline { font-size: 0.82rem; color: var(--warm-gray-5); }
      .footer-links { display: flex; gap: 24px; align-items: center; }
      .footer-links a { color: var(--warm-gray-4); text-decoration: none; font-size: 0.88rem; transition: color 0.15s; }
      .footer-links a:hover { color: var(--white); }
      .footer-bottom { border-top: 1px solid rgba(255,255,255,0.06); margin-top: 32px; padding-top: 24px; font-size: 0.8rem; color: var(--warm-gray-6); }

      /* ---- Responsive ---- */
      @media (max-width: 768px) {
        section { padding: 56px 0; }
        #hero { padding: 72px 0 56px; }
        .problem-grid { grid-template-columns: 1fr; }
        .steps { grid-template-columns: 1fr; }
        .gallery-grid { grid-template-columns: 1fr; }
        .badge-section-inner { grid-template-columns: 1fr; }
        .nav-links { display: none; }
      }
    </style>
  </head>

  <body>
    <a href="#main" class="skip-link">Skip to main content</a>

    <!-- Nav -->
    <nav aria-label="Main navigation">
      <div class="container">
        <div class="nav-inner">
          <a href="/" class="nav-logo" aria-label="Runbook home">
            <div class="nav-logo-mark" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="5" height="5" rx="1" fill="white" opacity="0.9"/>
                <rect x="9" y="2" width="5" height="5" rx="1" fill="white" opacity="0.6"/>
                <rect x="2" y="9" width="5" height="5" rx="1" fill="white" opacity="0.6"/>
                <rect x="9" y="9" width="5" height="5" rx="1" fill="white" opacity="0.4"/>
              </svg>
            </div>
            Runbook
          </a>
          <nav class="nav-links" aria-label="Site sections">
            <a href="#problem">Problem</a>
            <a href="#how">How it works</a>
            <a href="#gallery">Gallery</a>
            <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href={APP_URL} class="btn-nav-cta">Try it free</a>
          </nav>
        </div>
      </div>
    </nav>

    <main id="main">

      <!-- ================================================
           HERO
           ================================================ -->
      <section id="hero" aria-labelledby="hero-heading">
        <div class="container">
          <span class="section-label">Open source · Free forever</span>
          <h1 id="hero-heading" class="hero-tagline">
            Version your APIs<br/>the way you <span>version your code</span>.
          </h1>
          <p class="hero-sub">
            Build API workflows from reusable blocks. Ship them to your team as a single signed JSON bundle. Stay in sync as APIs change — no more silent rot.
          </p>
          <div class="hero-actions">
            <a href={APP_URL} class="btn btn-primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polygon points="5,3 19,12 5,21"/>
              </svg>
              Try in browser — no signup
            </a>
            <a href={GITHUB_URL} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
